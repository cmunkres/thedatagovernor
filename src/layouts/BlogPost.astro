---
import BaseLayout from './BaseLayout.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import NewsletterCTA from '@/components/NewsletterCTA.astro';

interface FaqPair { q: string; a: string; }

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  categories?: string[];
  tags?: string[];
  slug: string;
  image?: string;
  imageAlt?: string;
  ogImage?: string;
  faqPairs?: FaqPair[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'The Data Governor',
  categories = [],
  tags = [],
  slug,
  image,
  imageAlt = title,
  ogImage,
  faqPairs = [],
} = Astro.props;

const primaryCategory = categories[0];
const catSlug = primaryCategory?.toLowerCase().replace(/\s+/g, '-');
const canonicalUrl = `https://thedatagovernor.com/${slug}/`;

const fmtLong = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const fmtUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const shareUrl = encodeURIComponent(canonicalUrl);
const shareTitle = encodeURIComponent(title);
const shareLinks = {
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`,
  twitter: `https://x.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`,
  bluesky: `https://bsky.app/intent/compose?text=${shareTitle}%20${shareUrl}`,
  email: `mailto:?subject=${shareTitle}&body=${shareUrl}`,
};
---

<BaseLayout
  title={`${title} | The Data Governor`}
  description={description}
  canonicalPath={`/${slug}/`}
  ogImage={ogImage ?? image ?? `/og/auto/${slug}.png`}
  pubDate={pubDate}
  updatedDate={updatedDate}
  type="article"
  schema={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "@id": `https://thedatagovernor.com/${slug}/#article`,
        "headline": title,
        "description": description,
        "url": `https://thedatagovernor.com/${slug}/`,
        "datePublished": pubDate.toISOString(),
        "dateModified": (updatedDate ?? pubDate).toISOString(),
        "author": { "@type": "Person", "@id": "https://thedatagovernor.com/about/#person", "name": author },
        "publisher": {
          "@type": "Organization",
          "@id": "https://thedatagovernor.com/#organization",
          "name": "The Data Governor",
          "url": "https://thedatagovernor.com",
          "logo": { "@type": "ImageObject", "url": "https://thedatagovernor.com/logo.png" }
        },
        "image": ogImage ? `https://thedatagovernor.com${ogImage}` : `https://thedatagovernor.com/logo.png`,
        "mainEntityOfPage": { "@type": "WebPage", "@id": `https://thedatagovernor.com/${slug}/` },
        ...(categories.length > 0 ? { "articleSection": categories[0] } : {}),
        ...(tags.length > 0 ? { "keywords": tags.join(', ') } : {}),
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thedatagovernor.com/" },
          ...(categories[0] ? [{
            "@type": "ListItem",
            "position": 2,
            "name": categories[0],
            "item": `https://thedatagovernor.com/category/${categories[0].toLowerCase().replace(/\s+/g, '-')}/`,
          }] : []),
          {
            "@type": "ListItem",
            "position": categories[0] ? 3 : 2,
            "name": title,
            "item": `https://thedatagovernor.com/${slug}/`,
          },
        ],
      },
      ...(faqPairs.length > 0 ? [{
        "@type": "FAQPage",
        "mainEntity": faqPairs.map(({ q, a }) => ({
          "@type": "Question",
          "name": q,
          "acceptedAnswer": { "@type": "Answer", "text": a },
        })),
      }] : []),
    ],
  })}
>
  <!-- Article header -->
  <header class="article-header">
    <div class="article-header__inner" class:list={[image ? 'article-header__inner--with-img' : '']}>
      {image && (
        <div class="article-header__thumb">
          <img
            src={image}
            alt={imageAlt}
            width="480"
            height="320"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      )}

      <div class="article-header__text">
        {primaryCategory && (
          <a href={`/category/${catSlug}/`} class="label article-header__cat">{primaryCategory}</a>
        )}
        <h1 class="article-header__title">{title}</h1>
        <p class="article-header__deck">{description}</p>
        <div class="article-header__meta">
          <span class="article-header__author">{author}</span>
          <span class="article-header__sep" aria-hidden="true">·</span>
          <time datetime={pubDate.toISOString()} class="article-header__date">{fmtLong}</time>
          {updatedDate && (
            <>
              <span class="article-header__sep" aria-hidden="true">·</span>
              <span class="article-header__updated">Updated <time datetime={updatedDate.toISOString()}>{fmtUpdated}</time></span>
            </>
          )}
        </div>

        <!-- Tags/categories -->
        {(categories.length > 0 || tags.length > 0) && (
          <div class="article-header__tags">
            {categories.map(c => (
              <a href={`/category/${c.toLowerCase().replace(/\s+/g, '-')}/`} class="tag-pill tag-pill--cat">{c}</a>
            ))}
            {tags.slice(0, 6).map(t => (
              <span class="tag-pill">{t}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </header>

  <!-- Thin red rule under header -->
  <div class="article-rule" aria-hidden="true"></div>

  <!-- Article body -->
  <div class="article-layout">
    <article class="article-body prose">
      <slot />

      <!-- Inline newsletter capture -->
      <NewsletterCTA variant="inline" />

      <!-- Related posts -->
      <RelatedPosts
        currentSlug={slug}
        categories={categories}
        tags={tags}
        limit={3}
      />

      <!-- Share section -->
      <div class="share-block">
        <span class="share-block__label">Share</span>
        <div class="share-block__buttons">
          <a class="share-btn" href={shareLinks.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
          <a class="share-btn" href={shareLinks.twitter} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.6l5.24 6.93L18.9 1.15zm-1.29 19.5h2.04L6.49 3.24H4.3L17.61 20.65z"/></svg>
          </a>
          <a class="share-btn" href={shareLinks.facebook} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          </a>
          <a class="share-btn" href={shareLinks.bluesky} target="_blank" rel="noopener noreferrer" aria-label="Share on Bluesky">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.2 1.62C7.95 3.96 10.91 8.72 12 11.27v6.74c0-.14-.05.02-.15.37-.57 1.89-2.78 9.27-7.85 3.37-2.67-3.11-1.43-6.21 3.42-7.15-2.78.54-5.9-.35-6.76-3.83C.42 9.77 0 3.61 0 2.78 0-1.39 3.22-.08 5.2 1.62zm13.6 0C16.05 3.96 13.09 8.72 12 11.27v6.74c0-.14.05.02.15.37.57 1.89 2.78 9.27 7.85 3.37 2.67-3.11 1.43-6.21-3.42-7.15 2.78.54 5.9-.35 6.76-3.83.25-1 .67-7.16.67-7.99C24-1.39 20.78-.08 18.8 1.62z"/></svg>
          </a>
          <a class="share-btn" href={shareLinks.email} aria-label="Share via Email">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 5.46v13.91c0 .9-.73 1.63-1.64 1.63h-3.82V11.73L12 16.64 5.45 11.73v9.27H1.64A1.64 1.64 0 0 1 0 19.37V5.46c0-2.02 2.31-3.18 3.93-1.96L5.45 4.64 12 9.55l6.55-4.91 1.53-1.14C21.69 2.28 24 3.43 24 5.46z"/></svg>
          </a>
        </div>
      </div>
    </article>

    <!-- Sticky sidebar -->
    <aside class="article-sidebar">
      <div class="article-sidebar__inner">
        <div class="article-sidebar__section">
          <h4 class="article-sidebar__heading">Category</h4>
          {primaryCategory
            ? <a href={`/category/${catSlug}/`} class="label">{primaryCategory}</a>
            : <span class="label">General</span>
          }
        </div>
        {tags.length > 0 && (
          <div class="article-sidebar__section">
            <h4 class="article-sidebar__heading">Topics</h4>
            <div class="article-sidebar__tags">
              {tags.slice(0, 8).map(t => (
                <span class="sidebar-tag">{t}</span>
              ))}
            </div>
          </div>
        )}
        <div class="article-sidebar__section">
          <h4 class="article-sidebar__heading">Published</h4>
          <span class="article-sidebar__date">{fmtLong}</span>
        </div>
        <a href="/blog/" class="article-sidebar__back">← All articles</a>
      </div>
    </aside>
  </div>

  <!-- Post footer nav -->
  <div class="page-wrap">
    <div class="article-footer">
      <a href="/blog/" class="article-footer__back">← Back to all articles</a>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Article header ────────────────────────────────── */
  .article-header {
    background: var(--dark-bg);
    color: #f0ece6;
    padding: 3rem 2rem 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .article-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(193,18,31,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .article-header__inner {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
  }

  .article-header__cat {
    color: var(--gold) !important;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .article-header__cat:hover { color: #fff !important; }

  .article-header__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #f8f5f0;
    margin-bottom: 1.1rem;
  }

  .article-header__deck {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.65;
    color: #a09890;
    font-style: italic;
    max-width: 680px;
    margin-bottom: 1.5rem;
  }

  .article-header__meta {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #786e66;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .article-header__author { color: #a09890; }
  .article-header__sep { opacity: 0.4; }
  .article-header__updated { color: #786e66; }

  .article-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-pill {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.6rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: #a09890;
    border-radius: 2px;
  }

  .tag-pill--cat {
    background: rgba(193,18,31,0.25);
    border-color: rgba(193,18,31,0.4);
    color: #e8a0a5;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tag-pill--cat:hover { background: var(--red); color: #fff; }

  /* ── Header with thumbnail ───────────────────────── */
  .article-header__inner--with-img {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .article-header__text {
    display: flex;
    flex-direction: column;
  }

  .article-header__thumb {
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .article-header__thumb img {
    width: 100%;
    height: auto;
    max-height: 300px;
    object-fit: contain;
    display: block;
    margin: 0;
    border-radius: 3px;
  }

  /* ── Rule ───────────────────────────────────────── */
  .article-rule {
    height: 3px;
    background: linear-gradient(90deg, var(--red) 0%, var(--gold) 50%, transparent 100%);
  }

  /* ── Two-column article layout ──────────────────── */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 0;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    align-items: start;
  }

  /* ── Prose / article body ───────────────────────── */
  .article-body {
    padding: 3rem 3rem 3rem 0;
    border-right: 1px solid var(--rule);
    max-width: 740px;
  }

  .prose {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.8;
    color: var(--ink);
  }

  /* Drop cap on first paragraph */
  .prose :global(p:first-of-type::first-letter) {
    font-family: var(--font-body);
    font-size: 3.2em;
    font-weight: 700;
    float: left;
    line-height: 0.82;
    margin: 0.05em 0.1em 0 0;
    color: var(--red);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--ink);
    margin: 2.5rem 0 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    scroll-margin-top: 100px;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--ink);
    margin: 2rem 0 0.5rem;
    scroll-margin-top: 100px;
  }

  .prose :global(h4) {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin: 1.75rem 0 0.5rem;
    scroll-margin-top: 100px;
  }

  .prose :global(p) { margin-bottom: 1.4rem; }

  .prose :global(a) {
    color: var(--red);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) { color: var(--red-dark); }

  .prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    border-left: 4px solid var(--red);
    background: rgba(193,18,31,0.04);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--ink-mid);
  }

  .prose :global(blockquote p:last-child) { margin-bottom: 0; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.4rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .prose :global(li::marker) { color: var(--red); }

  .prose :global(code) {
    font-size: 0.85em;
    background: rgba(25,22,18,0.07);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-family: 'Fira Code', 'Courier New', monospace;
  }

  .prose :global(pre) {
    background: var(--dark-bg);
    color: #d0c8c0;
    padding: 1.5rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.4rem;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.4rem;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: #f8f5f0;
    padding: 0.6rem 0.9rem;
    text-align: left;
  }

  .prose :global(td) {
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
  }

  .prose :global(tr:nth-child(even) td) { background: rgba(25,22,18,0.03); }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    border-radius: 2px;
    margin: 1.5rem 0;
    max-width: 100%;
  }

  /* ── Sidebar ────────────────────────────────────── */
  .article-sidebar {
    position: sticky;
    top: 80px;
  }

  .article-sidebar__inner {
    padding: 2rem 0 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .article-sidebar__section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .article-sidebar__heading {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.25rem;
  }

  .article-sidebar__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sidebar-tag {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--ink-mid);
    background: rgba(25,22,18,0.06);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }

  .article-sidebar__date {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--ink-mid);
  }

  .article-sidebar__back {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--red);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .article-sidebar__back:hover { opacity: 0.75; }

  /* ── Share block ────────────────────────────────── */
  .share-block {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    margin-top: 2.5rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .share-block__label {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .share-block__buttons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .share-block .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--rule);
    color: var(--ink-mid);
    text-decoration: none;
    background: transparent;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .share-block .share-btn:hover {
    border-color: var(--ink);
    color: var(--ink);
    background: rgba(25,22,18,0.04);
  }

  .share-block .share-btn svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    display: block;
  }

  /* ── Article footer ─────────────────────────────── */
  .article-footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--rule);
    margin-top: 1rem;
  }

  .article-footer__back {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.15s;
  }
  .article-footer__back:hover { color: var(--red); }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 900px) {
    .article-layout {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }
    .article-body {
      border-right: none;
      padding: 2rem 0;
    }
    .article-sidebar {
      position: static;
      border-top: 1px solid var(--rule);
    }
    .article-sidebar__inner {
      padding: 1.5rem 0;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .article-sidebar__section { min-width: 140px; }
