---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p => (p.data.wpSlug ?? p.slug) !== 'welcome')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function slug(p: typeof posts[0]) { return p.data.wpSlug ?? p.slug; }
function cat(p: typeof posts[0]) { return p.data.categories?.[0] ?? ''; }
function catSlug(c: string) { return c.toLowerCase().replace(/\s+/g, '-'); }
function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="All Articles | The Data Governor"
  description="Every article on data governance, data management, metadata, and data strategy."
  canonicalPath="/blog/"
>
  <div class="page-wrap">
    <div class="archive-header animate-in">
      <h1 class="archive-title">The Archive</h1>
      <p class="archive-sub">{posts.length} articles on data governance and management</p>
    </div>

    <div class="archive-divider" aria-hidden="true"></div>

    <div class="archive-list">
      {posts.map((p, i) => (
        <article class={`archive-item animate-in`}>
          <span class="archive-item__num">{String(i + 1).padStart(3, '0')}</span>
          <div class="archive-item__body">
            {cat(p) && (
              <a href={`/category/${catSlug(cat(p))}/`} class="label">{cat(p)}</a>
            )}
            <a href={`/${slug(p)}/`} class="archive-item__title">{p.data.title}</a>
            <p class="archive-item__excerpt">{p.data.description}</p>
          </div>
          <time datetime={p.data.pubDate.toISOString()} class="archive-item__date">{fmt(p.data.pubDate)}</time>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .archive-header {
    padding: 3rem 0 1.5rem;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 0;
  }

  .archive-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .archive-sub {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: 0.5rem;
  }

  .archive-divider {
    height: 1px;
    background: var(--rule);
    margin-bottom: 0;
  }

  .archive-list {
    display: flex;
    flex-direction: column;
  }

  .archive-item {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .archive-item:hover { background: rgba(25,22,18,0.025); margin: 0 -1rem; padding: 1.5rem 1rem; }

  .archive-item__num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--rule-dark);
    line-height: 1;
    padding-top: 0.15rem;
    text-align: right;
  }

  .archive-item__body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .archive-item__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .archive-item__title:hover { color: var(--red); }

  .archive-item__excerpt {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--ink-mid);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .archive-item__date {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
    padding-top: 0.2rem;
  }

  @media (max-width: 640px) {
    .archive-item { grid-template-columns: 40px 1fr; }
    .archive-item__date { grid-column: 2; padding-top: 0; }
    .archive-item__num { font-size: 1.4rem; }
  }
</style>
