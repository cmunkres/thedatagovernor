---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | The Data Governor"
  description="Get in touch with The Data Governor — questions, collaboration, speaking engagements, or just a hello."
  canonicalPath="/contact/"
>
  <div class="page-wrap">
    <div class="page-header">
      <a href="/" class="label" style="font-size:0.65rem; letter-spacing:0.14em;">The Data Governor</a>
      <h1 class="page-title">Contact</h1>
    </div>
    <div class="article-rule" aria-hidden="true"></div>

    <div class="page-body">
      <div class="contact-grid">
        <div class="contact-main prose">
          <p>
            Have a question about data governance? A topic you'd like to see covered? Interested in collaborating
            or a speaking engagement? I'd love to hear from you.
          </p>

          <h2>Email</h2>
          <p>
            The best way to reach me is by email:
            <a href="mailto:thedatagovernor@gmail.com">thedatagovernor@gmail.com</a>
          </p>

          <h2>LinkedIn</h2>
          <p>
            Connect with me professionally on
            <a href="https://www.linkedin.com/in/clintonmunkres/" target="_blank" rel="noopener">LinkedIn</a>.
            I'm active there and happy to connect with fellow practitioners.
          </p>

          <h2>YouTube</h2>
          <p>
            Subscribe to the
            <a href="https://www.youtube.com/@thedatagovernor" target="_blank" rel="noopener">Data Governor YouTube channel</a>
            for video content, walkthroughs, and presentations.
          </p>

          <h2>Response Time</h2>
          <p>
            I try to respond to all emails within a few business days. If your question is general enough to
            benefit other readers, I may address it in a future post.
          </p>
        </div>

        <aside class="contact-sidebar">
          <div class="contact-card">
            <h3>Quick Links</h3>
            <ul>
              <li><a href="/blog/">All Articles</a></li>
              <li><a href="/data-governance-videos/">Video Channel</a></li>
              <li><a href="/rss.xml">RSS Feed</a></li>
              <li><a href="/about/">About the Author</a></li>
            </ul>
          </div>

          <div class="contact-card">
            <h3>Topics</h3>
            <ul>
              <li><a href="/category/data-governance/">Data Governance</a></li>
              <li><a href="/category/data-management/">Data Management</a></li>
              <li><a href="/category/compliance/">Compliance</a></li>
              <li><a href="/category/career-in-data/">Career in Data</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .article-rule {
    height: 3px;
    background: linear-gradient(90deg, var(--red) 0%, var(--gold) 50%, transparent 100%);
    margin-bottom: 2.5rem;
  }

  .page-body { padding-bottom: 4rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3rem;
    align-items: start;
  }

  .prose {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.8;
    color: var(--ink);
  }
  .prose p { margin-bottom: 1.4rem; }
  .prose h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
    margin: 2rem 0 0.6rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
  }
  .prose a { color: var(--red); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--red-dark); }

  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 80px;
  }

  .contact-card {
    background: var(--dark-bg);
    padding: 1.25rem 1.5rem;
  }

  .contact-card h3 {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .contact-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact-card a {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    color: #c8c0b8;
    text-decoration: none;
    transition: color 0.15s;
  }
  .contact-card a:hover { color: #fff; }

  @media (max-width: 760px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-sidebar { position: static; }
  }
</style>
